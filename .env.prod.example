DATABASE_URL=postgresql+asyncpg://db_user:db_password@managed-db-host:5432/course_db
API_SECRET_KEY=replace-with-strong-random-secret
BASE_URL=https://your-api-domain.example.com
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=replace-with-your-prod-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com
ZOHO_CALLBACK_URL=
# If Zoho returns HTTP 400 on callback, try: ZOHO_CALLBACK_BODY_FORMAT=form
#ZOHO_CALLBACK_BODY_FORMAT=json

# Optional: Zoho CRM V8 — attach generated PDF public URL to record (OAuth refresh token)
# https://www.zoho.com/crm/developer/docs/api/v8/oauth-overview.html
#ZOHO_CLIENT_ID=
#ZOHO_CLIENT_SECRET=
#ZOHO_REFRESH_TOKEN=
#ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
#ZOHO_CRM_API_BASE=https://www.zohoapis.com
# Legacy fallback (used if specific vars below are empty)
#ZOHO_CRM_MODULE_API_NAME=Course_Outline
# Course outline flow (attach generated outline PDF link)
#ZOHO_CRM_OUTLINE_MODULE_API_NAME=Course_Outline
# Slides flow (fetch uploaded File Upload field `outline`)
#ZOHO_CRM_SLIDES_MODULE_API_NAME=Batch_Details
#ZOHO_ATTACH_PDF_LINK_TO_CRM=false

# Slides LangGraph multi-bot pipeline (optional overrides)
#SLIDES_PLANNER_MODEL=claude-sonnet-4-20250514
#SLIDES_GENERATOR_MODEL=claude-3-5-haiku-latest
#SLIDES_VALIDATOR_MODEL=claude-3-5-haiku-latest
#SLIDES_VALIDATION_MAX_LOOPS=2
#SLIDES_MIN_PER_MODULE=10
#SLIDES_MAX_PER_MODULE=20
