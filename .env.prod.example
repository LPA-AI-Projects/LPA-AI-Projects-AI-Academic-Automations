DATABASE_URL=postgresql+asyncpg://db_user:db_password@managed-db-host:5432/course_db
API_SECRET_KEY=replace-with-strong-random-secret
BASE_URL=https://your-api-domain.example.com
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=replace-with-your-prod-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com
ZOHO_CALLBACK_URL=
# If Zoho returns HTTP 400 on callback, try: ZOHO_CALLBACK_BODY_FORMAT=form
#ZOHO_CALLBACK_BODY_FORMAT=json

# Optional: Zoho CRM V8 — attach generated PDF public URL to record (OAuth refresh token)
# https://www.zoho.com/crm/developer/docs/api/v8/oauth-overview.html
#ZOHO_CLIENT_ID=
#ZOHO_CLIENT_SECRET=
#ZOHO_REFRESH_TOKEN=
#ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
#ZOHO_CRM_API_BASE=https://www.zohoapis.com
# Legacy fallback (used if specific vars below are empty)
#ZOHO_CRM_MODULE_API_NAME=Course_Outline
# Course outline flow (attach generated outline PDF link)
#ZOHO_CRM_OUTLINE_MODULE_API_NAME=Course_Outline
# Slides flow (fetch uploaded File Upload field `outline`)
#ZOHO_CRM_SLIDES_MODULE_API_NAME=Batch_Details
# Slides flow write-back field for module gamma links text
#ZOHO_CRM_SLIDES_LINKS_FIELD_API_NAME=Link_for_Courseware
# Separate CRM field that receives the pre/post courseware assessment URLs
#ZOHO_CRM_ASSESSMENT_LINKS_FIELD_API_NAME=Links_for_Pre_Post
#ZOHO_ATTACH_PDF_LINK_TO_CRM=false

# Public course outline (course_type=public): Google Sheet as CSV (stable export URL recommended).
# See app/services/public_course_sheet.py — URL normalization + column detection.
#PUBLIC_COURSE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=0
#PUBLIC_COURSE_SHEET_LOOKUP_ENABLED=true
# Optional explicit headers if fuzzy match fails: e.g. Program_Name, Final_Formatted_Curriculum
#PUBLIC_COURSE_SHEET_COURSE_COLUMN=
#PUBLIC_COURSE_SHEET_PDF_COLUMN=
# Legacy alias if PUBLIC_COURSE_SHEET_CSV_URL is empty:
#PUBLIC_COURSE_CATALOG_CSV_URL=
# Optional: Zoho CRM field API name to write that curriculum URL on the outline record.
#ZOHO_CRM_PUBLIC_FINAL_CURRICULUM_FIELD_API_NAME=Final_Formatted_Curriculum

# Vercel-hosted frontend that serves /assessment/{zoho_record_id}/pre|post.
# When empty, slides job completion will not mint pre/post URLs.
# Example: https://frondend-one.vercel.app
#FRONTEND_BASE_URL=https://frondend-one.vercel.app
# HMAC secret used to mint the optional ?t= signed token on each public link.
# If empty, links are issued without a token (still safe behind X-API-Key on the
# Vercel proxy, but anyone who knows zoho_record_id could replay calls).
#ASSESSMENT_LINK_SECRET=replace-with-strong-random-secret
# When true, /api/v1/courseware-assessments/* requires a valid t= even when an
# X-API-Key is also presented. Use this to harden public learner URLs.
#ASSESSMENT_LINK_REQUIRE_TOKEN=false
# Per-IP and per-record rate limit (req/min) on the public generate endpoint.
#ASSESSMENT_RATE_LIMIT_PER_MIN=12
# Default difficulty + question count for on-demand pre assessments when the
# request doesn't override.
#COURSEWARE_ASSESSMENT_DEFAULT_DIFFICULTY=intermediate
#COURSEWARE_ASSESSMENT_DEFAULT_NUM_QUESTIONS=15
# When true (default), inline a copy of validated_slides into payload_json so
# multi-replica deployments don't depend on shared on-disk cache for /post.
#COURSEWARE_VALIDATED_BLOB_IN_PAYLOAD=true

# Slides LangGraph multi-bot pipeline (optional overrides)
#SLIDES_PLANNER_MODEL=claude-sonnet-4-20250514
#SLIDES_GENERATOR_MODEL=claude-3-5-haiku-latest
#SLIDES_VALIDATOR_MODEL=claude-3-5-haiku-latest
#SLIDES_VALIDATION_MAX_LOOPS=2
#SLIDES_MIN_PER_MODULE=10
#SLIDES_MAX_PER_MODULE=20
#SLIDES_MODULE_PARALLELISM=3
# supplement (default) or primary — when primary, instructor PPT drives factual slide detail; outline still defines modules
#SLIDES_INSTRUCTOR_PPT_PRIORITY=supplement

# Gamma optional template + sharing controls
#GAMMA_USE_TEMPLATE=false
#GAMMA_TEMPLATE_ID=
# Optional theme for generated output (from-template). Omit for workspace default.
#GAMMA_THEME_ID=
# Sharing: https://developers.gamma.app/guides/create-from-template-api-parameters-explained
#GAMMA_WORKSPACE_ACCESS=edit
#GAMMA_EXTERNAL_ACCESS=edit
#GAMMA_EMAIL_EDIT_LIST=ceo@example.com,cto@example.com
# Access for email recipients: view | comment | edit | fullAccess (default edit if empty)
#GAMMA_EMAIL_OPTIONS_ACCESS=comment
# Optional from-template only — omit all three to use Gamma defaults for images
#GAMMA_IMAGE_SOURCE=aiGenerated
#GAMMA_IMAGE_MODEL=flux-1-pro
#GAMMA_IMAGE_STYLE=minimal, black and white, line art
# Non-template only: let Gamma infer card count automatically (default false = send numCards explicitly)
#GAMMA_AUTO_CARD_COUNT=false
