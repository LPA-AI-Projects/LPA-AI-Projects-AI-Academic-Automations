DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/course_db
API_SECRET_KEY=dev-local-secret-change-me
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=replace-with-your-dev-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Google Drive (course outline PDF upload): OAuth desktop/web client + refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional: parent folder for per-course subfolders; or legacy GOOGLE_DRIVE_FOLDER_ID
GOOGLE_DRIVE_COURSE_OUTLINES_PARENT_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_ID=

# Zoho: completion webhook (non-localhost URL in production)
ZOHO_CALLBACK_URL=
ZOHO_CALLBACK_BODY_FORMAT=json

# Zoho CRM: attach PDF link to record (requires OAuth below + ZOHO_ATTACH_PDF_LINK_TO_CRM=true)
ZOHO_ATTACH_PDF_LINK_TO_CRM=false
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_CRM_API_BASE=https://www.zohoapis.com
ZOHO_CRM_MODULE_API_NAME=Course_Outline
ZOHO_CRM_OUTLINE_MODULE_API_NAME=

# Bitrix24 course outline (incoming webhook — Applications → Developer resources)
# Full base URL only (no method suffix). Trailing slash optional. Example shape:
# https://learnerspoint.bitrix24.com/rest/USER_ID/WEBHOOK_SECRET/
BITRIX_WEBHOOK_URL=
# Outgoing webhook token from Bitrix payload auth[application_token] (not the incoming REST webhook code)
BITRIX_APPLICATION_TOKEN=
BITRIX_CRM_ENTITY=deal
BITRIX_CRM_ENTITY_TYPE_ID=2
BITRIX_OUTLINE_PDF_FIELD=
BITRIX_OUTLINE_STATUS_FIELD=
BITRIX_ATTACH_PDF_TO_CRM=false
BITRIX_PUBLIC_FINAL_CURRICULUM_FIELD=
BITRIX_CALLBACK_URL=
BITRIX_CALLBACK_BODY_FORMAT=json
# Disk folder id for outline PDF upload (disk.folder.uploadfile) before tasks.task.files.attach
BITRIX_DRIVE_FOLDER_ID=
BITRIX_TASK_ATTACH_ENABLED=true
# Optional; default message is built in code if empty
BITRIX_TASK_CHAT_MESSAGE=
# Set true to log every Bitrix POST URL/query/body in Railway logs (debug 401)
BITRIX_LOG_INCOMING_REQUESTS=false
# ONTASKCOMMENTADD: comments starting with this prefix queue outline refine (v2+)
BITRIX_REFINE_COMMENT_PREFIX=Refine:
