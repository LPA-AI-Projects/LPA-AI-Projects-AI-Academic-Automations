DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/course_db
API_SECRET_KEY=dev-local-secret-change-me
BASE_URL=http://localhost:8000
# CodeSandbox SDK (Devbox / VM sandbox): create token at https://codesandbox.io/t/api
CODESANDBOX_API_TOKEN=
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=replace-with-your-dev-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Google Drive (course outline PDF upload): OAuth desktop/web client + refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional: parent folder for per-course subfolders; or legacy GOOGLE_DRIVE_FOLDER_ID
GOOGLE_DRIVE_COURSE_OUTLINES_PARENT_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_ID=

# Zoho: completion webhook (non-localhost URL in production)
ZOHO_CALLBACK_URL=
ZOHO_CALLBACK_BODY_FORMAT=json

# Zoho CRM: attach PDF link to record (requires OAuth below + ZOHO_ATTACH_PDF_LINK_TO_CRM=true)
ZOHO_ATTACH_PDF_LINK_TO_CRM=false
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_CRM_API_BASE=https://www.zohoapis.com
ZOHO_CRM_MODULE_API_NAME=Course_Outline
ZOHO_CRM_OUTLINE_MODULE_API_NAME=

# Public course catalog (Google Sheet as CSV). When input_data.course_type is public (or pub),
# the job matches input_data.course_name to a row and reuses the PDF link column (no AI/PDF generation).
# Use the stable export URL (not the /edit page):
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=<TAB_GID>
# Share the sheet so "Anyone with the link" can view, or CSV download may fail.
PUBLIC_COURSE_SHEET_CSV_URL=
PUBLIC_COURSE_SHEET_LOOKUP_ENABLED=true
# Optional: exact header text in row 1 if auto-detection fails (case-insensitive).
PUBLIC_COURSE_SHEET_COURSE_COLUMN=
PUBLIC_COURSE_SHEET_PDF_COLUMN=

# Optional sidecar assessments in slides flow (safe: disabled by default).
SLIDES_ASSESSMENTS_ENABLED=false
SLIDES_PRE_ASSESSMENT_QUESTIONS=12
SLIDES_POST_ASSESSMENT_QUESTIONS=18

